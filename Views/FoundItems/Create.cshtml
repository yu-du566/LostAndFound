@model LostAndFound.Models.FoundItem
@{ ViewData["Title"] = "发布招领"; }
<h3>📝 发布招领信息</h3>

@if (ViewBag.FromLostId != null)
{
    <div class="alert alert-info">
        <strong>📦 你正在帮「@ViewBag.LostItemPublisher」找回失物</strong><br/>
        <small>以下信息已根据失物自动填充，请补充你捡到该物品的具体时间和地点。</small>
    </div>
}

@if (ViewBag.DuplicateWarning != null) { <div class="alert alert-warning">⚠️ @ViewBag.DuplicateWarning</div> }
@if (ViewBag.AiSuggestedCategory != null) { <div class="alert alert-success">🤖 AI 已识别分类：<strong>@ViewBag.AiSuggestedCategory</strong></div> }

<div class="card shadow"><div class="card-body"><form asp-action="Create" method="post" enctype="multipart/form-data">
@if (ViewBag.FromLostId != null) { <input type="hidden" name="fromLostId" value="@ViewBag.FromLostId" /> }
<div class="row">
<div class="col-md-6 mb-3"><label class="form-label">物品名称</label><input asp-for="ItemName" class="form-control" required value="@(ViewBag.PreFillName ?? "")" /></div>
<div class="col-md-6 mb-3"><label class="form-label">物品类别</label><select asp-for="Category" class="form-select" required>
@foreach (var c in (string[])ViewBag.Categories) { <option selected="@(ViewBag.PreFillCategory != null && ViewBag.PreFillCategory == c)">@c</option> }
</select></div>
</div>
<div class="row">
<div class="col-md-6 mb-3"><label class="form-label">拾获时间</label><input asp-for="FoundTime" type="datetime-local" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" /></div>
<div class="col-md-6 mb-3"><label class="form-label">拾获地点</label><input asp-for="FoundLocation" class="form-control" required placeholder="如：思源楼门口" value="@(ViewBag.PreFillLocation ?? "")" /></div>
</div>
<div class="mb-3"><label class="form-label">特征描述</label><textarea asp-for="Description" class="form-control" rows="3" placeholder="描述物品特征...">@(ViewBag.PreFillDescription ?? "")</textarea></div>
<div class="mb-3"><label class="form-label">物品图片（可选）</label><input type="file" name="imageFile" class="form-control" accept="image/*" /><small class="text-muted">支持 JPG、PNG、GIF，最大 2MB</small></div>
<button type="submit" class="btn btn-success">提交发布</button><a asp-action="Index" class="btn btn-secondary">返回</a>
</form></div></div>
