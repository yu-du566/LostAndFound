@model LostAndFound.Models.FoundItem
@{ ViewData["Title"] = "招领详情"; }
<div class="card shadow"><div class="card-header bg-success text-white"><h4 class="mb-0">招领详情</h4></div><div class="card-body">
<dl class="row">
<dt class="col-sm-3">物品名称</dt><dd class="col-sm-9">@Model.ItemName</dd>
<dt class="col-sm-3">类别</dt><dd class="col-sm-9">@Model.Category</dd>
<dt class="col-sm-3">拾获时间</dt><dd class="col-sm-9">@Model.FoundTime.ToString("yyyy-MM-dd HH:mm")</dd>
<dt class="col-sm-3">拾获地点</dt><dd class="col-sm-9">@Model.FoundLocation</dd>
<dt class="col-sm-3">特征描述</dt><dd class="col-sm-9">@(Model.Description ?? "无")</dd>
<dt class="col-sm-3">状态</dt><dd class="col-sm-9"><span class="badge @(Model.Status=="未认领"?"bg-danger":"bg-warning")">@Model.Status</span></dd>
<dt class="col-sm-3">发布者</dt><dd class="col-sm-9">@Model.Publisher?.RealName</dd>
</dl>
@if(Model.Status=="未认领"){<a asp-controller="Claims" asp-action="Apply" asp-route-type="Found" asp-route-id="@Model.Id" class="btn btn-warning">申请认领</a>}
<a asp-action="Index" class="btn btn-secondary">返回</a>
</div></div>