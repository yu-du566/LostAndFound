@model LostAndFound.Models.LostItem
@{ ViewData["Title"] = "编辑失物"; }
<h3>✏️ 编辑失物</h3>
<div class="card shadow"><div class="card-body">
<form asp-action="Edit" method="post">
<div class="row">
<div class="col-md-6 mb-3"><label class="form-label">物品名称</label><input asp-for="ItemName" class="form-control" required /></div>
<div class="col-md-6 mb-3"><label class="form-label">物品类别</label><select asp-for="Category" class="form-select" required>@foreach(var c in (string[])ViewBag.Categories){<option>@c</option>}</select></div>
</div>
<div class="row">
<div class="col-md-6 mb-3"><label class="form-label">丢失时间</label><input asp-for="LostTime" type="datetime-local" class="form-control" required value="@Model.LostTime.ToString("yyyy-MM-ddTHH:mm")" /></div>
<div class="col-md-6 mb-3"><label class="form-label">丢失地点</label><input asp-for="LostLocation" class="form-control" required /></div>
</div>
<div class="mb-3"><label class="form-label">特征描述</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
<button type="submit" class="btn btn-primary">保存修改</button>
<a asp-action="MyLostItems" class="btn btn-secondary">取消</a>
</form></div></div>