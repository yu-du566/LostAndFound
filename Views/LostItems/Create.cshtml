@model LostAndFound.Models.LostItem
@{ ViewData["Title"] = "发布失物"; }
<h3>📝 发布失物信息</h3>
@if (ViewBag.DuplicateWarning != null)
{
    <div class="alert alert-warning">⚠️ @ViewBag.DuplicateWarning
    @if (ViewBag.Duplicates != null) { foreach (var d in (List<(double, LostAndFound.Models.LostItem)>)ViewBag.Duplicates) { <br/><a asp-action="Details" asp-route-id="@d.Item2.Id">@d.Item2.ItemName (相似度: @d.Item1.ToString("P0"))</a> } }
    </div>
}
<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3"><label class="form-label">物品名称</label><input asp-for="ItemName" class="form-control" required /></div>
                <div class="col-md-6 mb-3"><label class="form-label">物品类别</label><select asp-for="Category" class="form-select" required>
                    @foreach (var c in (string[])ViewBag.Categories) { <option>@c</option> }</select></div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3"><label class="form-label">丢失时间</label><input asp-for="LostTime" type="datetime-local" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" /></div>
                <div class="col-md-6 mb-3"><label class="form-label">丢失地点</label><input asp-for="LostLocation" class="form-control" required placeholder="如：图书馆二楼自习室" /></div>
            </div>
            <div class="mb-3"><label class="form-label">特征描述</label><textarea asp-for="Description" class="form-control" rows="3" placeholder="请描述物品的颜色、品牌、特殊标记等特征..."></textarea></div>
            <div class="mb-3">
                <label class="form-label">物品图片（可选）</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <small class="text-muted">支持 JPG、PNG、GIF 格式，最大 2MB</small>
            </div>
            <button type="submit" class="btn btn-primary">提交发布</button>
            <a asp-action="Index" class="btn btn-secondary">返回</a>
        </form>
    </div>
</div>