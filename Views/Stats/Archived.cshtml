@{ ViewData["Title"] = "📦 已归档物品"; }
<h3>📦 已归档物品（超过30天未认领）</h3>

<h5 class="mt-3">失物归档 (@(((List<LostAndFound.Models.LostItem>)ViewBag.ArchivedLost).Count) 条)</h5>
@if(((List<LostAndFound.Models.LostItem>)ViewBag.ArchivedLost).Any()){
<div class="table-responsive"><table class="table table-sm table-hover"><thead class="table-dark"><tr><th>物品名称</th><th>类别</th><th>发布者</th><th>发布时间</th><th>状态</th></tr></thead>
<tbody>@foreach(var i in (List<LostAndFound.Models.LostItem>)ViewBag.ArchivedLost){<tr><td>@i.ItemName</td><td>@i.Category</td><td>@i.Publisher?.RealName</td><td>@i.CreatedAt.ToString("MM-dd")</td><td>@i.Status</td></tr>}</tbody></table></div>
}else{<p class="text-muted">无归档失物</p>}

<h5 class="mt-3">招领归档 (@(((List<LostAndFound.Models.FoundItem>)ViewBag.ArchivedFound).Count) 条)</h5>
@if(((List<LostAndFound.Models.FoundItem>)ViewBag.ArchivedFound).Any()){
<div class="table-responsive"><table class="table table-sm table-hover"><thead class="table-dark"><tr><th>物品名称</th><th>类别</th><th>发布者</th><th>发布时间</th><th>状态</th></tr></thead>
<tbody>@foreach(var i in (List<LostAndFound.Models.FoundItem>)ViewBag.ArchivedFound){<tr><td>@i.ItemName</td><td>@i.Category</td><td>@i.Publisher?.RealName</td><td>@i.CreatedAt.ToString("MM-dd")</td><td>@i.Status</td></tr>}</tbody></table></div>
}else{<p class="text-muted">无归档招领</p>}

<a asp-action="Index" class="btn btn-secondary">返回统计面板</a>