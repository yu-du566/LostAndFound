@model LostAndFound.Models.Claim
@{ ViewData["Title"] = "审核认领申请"; }
<h3>🔍 审核认领申请</h3>
<div class="card shadow"><div class="card-body">
<h5>申请信息</h5>
<dl class="row">
<dt class="col-sm-3">申请人</dt><dd class="col-sm-9">@Model.Applicant?.RealName (@Model.Applicant?.Username)</dd>
<dt class="col-sm-3">物品名称</dt><dd class="col-sm-9">@(Model.LostItem?.ItemName ?? Model.FoundItem?.ItemName)</dd>
<dt class="col-sm-3">物品类型</dt><dd class="col-sm-9">@(Model.LostItemId!=null?"失物":"招领")</dd>
<dt class="col-sm-3">物品地点</dt><dd class="col-sm-9">@(Model.LostItem?.LostLocation ?? Model.FoundItem?.FoundLocation)</dd>
<dt class="col-sm-3">发布者</dt><dd class="col-sm-9">@(Model.LostItem?.Publisher?.RealName ?? Model.FoundItem?.Publisher?.RealName)</dd>
<dt class="col-sm-3">申请理由</dt><dd class="col-sm-9">@Model.Reason</dd>
<dt class="col-sm-3">申请时间</dt><dd class="col-sm-9">@Model.AppliedAt.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>
<hr />
<h5>审核操作</h5>
<form asp-action="Review" method="post">
<div class="mb-3"><label class="form-label">审核备注</label><textarea name="remark" class="form-control" rows="2"></textarea></div>
<button type="submit" name="action" value="approve" class="btn btn-success" onclick="return confirm('确认通过此认领申请？')">✅ 通过</button>
<button type="submit" name="action" value="reject" class="btn btn-danger" onclick="return confirm('确认拒绝此认领申请？')">❌ 拒绝</button>
<a asp-action="Pending" class="btn btn-secondary">返回</a>
</form>
</div></div>