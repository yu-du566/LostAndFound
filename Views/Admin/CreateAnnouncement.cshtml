@{ ViewData["Title"] = "发布公告"; }
<h3>📢 发布新公告</h3>
<div class="card shadow"><div class="card-body">
<form asp-action="CreateAnnouncement" method="post">
<div class="mb-3"><label class="form-label">公告标题</label><input name="title" class="form-control" required /></div>
<div class="mb-3"><label class="form-label">公告内容</label><textarea name="content" class="form-control" rows="5" required></textarea></div>
<div class="form-check mb-3"><input name="isTop" value="true" type="checkbox" class="form-check-input" id="isTop" /><label class="form-check-label" for="isTop">置顶公告</label></div>
<button type="submit" class="btn btn-primary">发布公告</button>
<a asp-action="Announcements" class="btn btn-secondary">返回</a>
</form></div></div>