@model LostAndFound.Models.User
@{ ViewData["Title"] = "编辑用户"; }
<h3>✏️ 编辑用户</h3>
<div class="card shadow"><div class="card-body">
<form asp-action="EditUser" method="post">
<div class="row"><div class="col-md-6 mb-3"><label class="form-label">用户名</label><input value="@Model.Username" class="form-control" readonly /></div>
<div class="col-md-6 mb-3"><label class="form-label">真实姓名</label><input name="realName" value="@Model.RealName" class="form-control" required /></div></div>
<div class="row"><div class="col-md-6 mb-3"><label class="form-label">角色</label><select name="role" class="form-select"><option selected="@(Model.Role=="User")">User</option><option selected="@(Model.Role=="Admin")">Admin</option></select></div>
<div class="col-md-6 mb-3"><label class="form-label">手机号</label><input name="phone" value="@Model.Phone" class="form-control" /></div></div>
<div class="mb-3"><label class="form-label">邮箱</label><input name="email" value="@Model.Email" class="form-control" /></div>
<button type="submit" class="btn btn-primary">保存修改</button>
<a asp-action="Users" class="btn btn-secondary">返回</a>
</form>
<hr /><h5>重置密码</h5>
<form asp-action="ResetPassword" asp-route-id="@Model.Id" method="post" class="row g-2">
<div class="col-md-6"><input name="newPassword" type="password" class="form-control" placeholder="新密码（至少6位）" required /></div>
<div class="col-md-2"><button type="submit" class="btn btn-warning" onclick="return confirm('确认重置密码？')">重置密码</button></div>
</form>
</div></div>