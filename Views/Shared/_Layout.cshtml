<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="失物招领" />
    <link rel="apple-touch-icon" href="/images/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>@ViewData["Title"] - 失物招领智能平台</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    📦 失物招领智能平台
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">首页</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">失物管理</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="LostItems" asp-action="Index">查询失物</a></li>
                                <li><a class="dropdown-item" asp-controller="LostItems" asp-action="Create">发布失物</a></li>
                                <li><a class="dropdown-item" asp-controller="LostItems" asp-action="MyLostItems">我的失物</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">🏆 排行统计</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Leaderboard" asp-action="Index">招领排行榜</a></li>
                                <li><a class="dropdown-item" asp-controller="Leaderboard" asp-action="MyStats">我的统计</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">招领管理</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="FoundItems" asp-action="Index">查询招领</a></li>
                                <li><a class="dropdown-item" asp-controller="FoundItems" asp-action="Create">发布招领</a></li>
                                <li><a class="dropdown-item" asp-controller="FoundItems" asp-action="MyFoundItems">我的招领</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">认领申请</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Claims" asp-action="MyClaims">我的申请</a></li>
                                @if (Context.Session.GetString("Role") == "Admin")
                                {
                                    <li><a class="dropdown-item" asp-controller="Claims" asp-action="Pending">待审核</a></li>
                                }
                            </ul>
                        </li>
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-warning" href="#" data-bs-toggle="dropdown">系统管理</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">用户管理</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Announcements">公告管理</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Logs">日志管理</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Stats" asp-action="Index">📊 数据统计</a></li>
                                    <li><a class="dropdown-item" asp-controller="Leaderboard" asp-action="Warnings">🔔 警告管理</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <span class="navbar-text text-light me-2">
                                    👤 @Context.Session.GetString("RealName")
                                    @if (Context.Session.GetString("Role") == "Admin")
                                    {
                                        <span class="badge bg-warning text-dark">管理员</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Profile">个人信息</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">退出</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">登录</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">注册</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        @if (TempData["SuccessMsg"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["SuccessMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMsg"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["ErrorMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["MatchMsg"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show">
                ℹ️ @TempData["MatchMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-3 mt-4 bg-light">
        <div class="container text-center text-muted">
            <small>&copy; 2026 失物招领智能平台 - 北京交通大学机械与电子控制工程学院</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
            navigator.serviceWorker.register('/service-worker.js')
                .then(function(reg) { console.log('[PWA] SW registered:', reg.scope); })
                .catch(function(err) { console.log('[PWA] SW failed:', err); });
        });
    }
    </script>
</body>
</html>