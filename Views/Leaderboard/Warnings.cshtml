@using LostAndFound.Models
@{ ViewData["Title"] = "🔔 警告管理"; }
<h3>🔔 警告与黑名单管理（管理员）</h3>

<h5 class="mt-3">🚫 当前黑名单用户</h5>
@if (((List<User>)ViewBag.Blacklisted).Any()){
<table class="table table-sm table-hover"><thead class="table-dark"><tr><th>用户名</th><th>姓名</th><th>警告次数</th><th>截止日期</th><th>操作</th></tr></thead>
<tbody>@foreach (var u in (List<User>)ViewBag.Blacklisted){
<tr><td>@u.Username</td><td>@u.RealName</td><td>@u.WarningCount</td><td>@u.BlacklistUntil?.ToString("yyyy-MM-dd")</td>
<td><form asp-action="Unban" method="post"><input type="hidden" name="userId" value="@u.Id"/><button class="btn btn-sm btn-success" onclick="return confirm('确认解除 @u.Username 的黑名单？')">解除拉黑</button></form></td></tr>}
</tbody></table>
}else{<p class="text-muted">暂无黑名单用户</p>}

<h5 class="mt-4">📋 警告记录（最近100条）</h5>
@if (((List<SystemLog>)ViewBag.Logs).Any()){
<table class="table table-sm table-hover"><thead class="table-dark"><tr><th>时间</th><th>类型</th><th>内容</th></tr></thead>
<tbody>@foreach (var l in (List<SystemLog>)ViewBag.Logs){<tr><td>@l.OperatedAt.ToString("MM-dd HH:mm")</td><td><span class="badge @(l.ActionType=="拉黑用户"?"bg-danger":"bg-warning")">@l.ActionType</span></td><td>@l.Content</td></tr>}</tbody></table>
}else{<p class="text-muted">暂无警告记录</p>}

<a asp-action="Index" class="btn btn-secondary">返回排行榜</a>